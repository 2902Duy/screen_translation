<Window x:Class="ScreenTranslator.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Overlay" 
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">
    <Grid>
        <Canvas x:Name="OverlayCanvas" />
        
        <!-- Loading Spinner / Status text -->
        <Border x:Name="LoadingIndicator" 
                Background="#80000000" 
                CornerRadius="5"
                Padding="10" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <ProgressBar IsIndeterminate="True" Width="20" Height="20" Margin="0,0,10,0" Foreground="#FF007ACC"/>
                <TextBlock Text="Đang dịch..." Foreground="White" VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
